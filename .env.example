# ── Trigger.dev ──────────────────────────────────────────────────────────────
# Get this from: cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── Gamma (document creation) ─────────────────────────────────────────────────
# Get this from: gamma.app → Settings → API Keys (requires Pro/Ultra/Teams/Business)
GAMMA_API_KEY=your_gamma_api_key_here

# ── n8n (callback / MCP) ──────────────────────────────────────────────────────
# Your n8n MCP endpoint URL
N8N_MCP_URL=https://your-n8n-instance.com/rest/mcp
# n8n API key (create in n8n → Settings → API)
N8N_API_KEY=your_n8n_api_key_here
