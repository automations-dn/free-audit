# Server Config
PORT=3000

# Trigger.dev Config
TRIGGER_SECRET_KEY=your_trigger_secret_key_here

# Anthropic (Claude) Config
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack Integration Config
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_AUDIT_CHANNEL_ID=C0123456789

# Zoho Bigin CRM Config
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=1000.your_refresh_token_here
ZOHO_PIPELINE_ID=your_sub_pipeline_id_here
ZOHO_PIPELINE_STAGE_ID=your_stage_id_here

# n8n MCP Integration Config
N8N_MCP_URL=https://your-n8n-instance.com/rest/mcp
N8N_API_KEY=your_n8n_api_key_here

