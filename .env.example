# ── Trigger.dev ──────────────────────────────────────────────────────────────
# Get this from: cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── Google PageSpeed Insights ─────────────────────────────────────────────────
# Optional but recommended — raises free quota from ~25/day to 25,000/day
# Get a free key: console.cloud.google.com → Enable "PageSpeed Insights API"
# → APIs & Services → Credentials → Create API Key
PAGESPEED_API_KEY=your_google_api_key_here

# ── Google Drive (audit document upload) ──────────────────────────────────────
# Service Account JSON — paste the entire contents of the downloaded key file on one line
# Setup: console.cloud.google.com → Enable "Google Drive API"
# → IAM & Admin → Service Accounts → Create → Keys → Add Key → JSON → download
# Then share your Drive folder with the service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"xxx@yyy.iam.gserviceaccount.com"}

# Folder ID: open the Drive folder → copy ID from the URL
# drive.google.com/drive/folders/{THIS_IS_THE_FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ── n8n (callback) ────────────────────────────────────────────────────────────
N8N_MCP_URL=https://your-n8n-instance.com/rest/mcp
N8N_API_KEY=your_n8n_api_key_here
