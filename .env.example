# Server Config
PORT=3000

# Trigger.dev Config
TRIGGER_SECRET_KEY=your_trigger_secret_key_here

# Anthropic (Claude) Config
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud (Service Account) Config
# Note: Google private key should have all actual newlines replaced with \n if written as a single line
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC..."
GOOGLE_SHEET_ID=your_google_spreadsheet_id_here
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Slack Integration Config
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_AUDIT_CHANNEL_ID=C0123456789

# Zoho Bigin CRM Config
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=1000.your_refresh_token_here
ZOHO_PIPELINE_ID=your_sub_pipeline_id_here
ZOHO_PIPELINE_STAGE_ID=your_stage_id_here

# SMTP Email Config (e.g. Resend, Gmail, SendGrid, custom SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_smtp_password_here
SMTP_FROM_EMAIL=audit@yourdomain.com
