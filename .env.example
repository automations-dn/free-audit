# ── Trigger.dev ──────────────────────────────────────────────────────────────
# Get this from: cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_dev_your_secret_key_here

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── n8n MCP (Google Drive upload only) ───────────────────────────────────────
# Your n8n MCP endpoint URL — the workflow that uploads files to Google Drive
N8N_MCP_URL=https://your-n8n-instance.com/rest/mcp
# n8n API key for the MCP connection (create in n8n → Settings → API)
N8N_API_KEY=your_n8n_api_key_here

# ── Google Drive (direct upload — no n8n MCP needed) ─────────────────────────
# Folder ID: open the Drive folder → copy ID from URL
# drive.google.com/drive/folders/{THIS_PART}
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Service Account JSON (one line — the entire contents of the downloaded key file)
# Setup: console.cloud.google.com → IAM → Service Accounts → Create → Keys → JSON
# Then share your Drive folder with the service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"xxx@yyy.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Express server (approval link fallback only) ──────────────────────────────
PORT=3000
WEBHOOK_SECRET=your-random-secret-string-here
